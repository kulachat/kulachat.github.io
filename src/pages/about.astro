---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="เกี่ยวกับ — kulachat"
  description="เว็บนี้เป็นสมุดบันทึกส่วนตัวของ kulachat ผู้ก่อตั้งเทคไทบ้าน"
>

  <main class="max-w-2xl mx-auto px-6 sm:px-8">
    <section class="py-20">
      <p class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-3">เกี่ยวกับ</p>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-10">
        สมุดบันทึกส่วนตัว
      </h1>

      <div class="space-y-6 text-lg text-gray-600 leading-relaxed thai">
        <p>
          เว็บนี้เป็นสมุดบันทึกส่วนตัวครับ
        </p>
        <p>
          ผมเกิดในชุมชนบ้านนอก สมัยเด็กเคยเป็นเด็กเลี้ยงควาย
          ชีวิตที่ผ่านมา เห็นการเปลี่ยนแปลงมาอย่างต่อเนื่อง ตั้งแต่ดูทีวีจอดำ
          มาจนถึงยุค AI
        </p>
        <p>
          ผมเป็นผู้ก่อตั้ง
          <a href="https://techthaiban.org/" target="_blank" rel="noopener noreferrer" class="text-gray-900 hover:text-black font-semibold underline underline-offset-2 transition-colors">เทคไทบ้าน</a>
          ทำงานด้านการศึกษากับมิตรสหายที่
          <a href="https://thaibanuniversity.com/" target="_blank" rel="noopener noreferrer" class="text-gray-900 hover:text-black font-semibold underline underline-offset-2 transition-colors">มหา'ลัยไทบ้าน</a>
          และ
          <a href="https://isaanjalearn.org/" target="_blank" rel="noopener noreferrer" class="text-gray-900 hover:text-black font-semibold underline underline-offset-2 transition-colors">อีสานจะเลิร์น</a>
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
