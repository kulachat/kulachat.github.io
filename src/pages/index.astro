---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCategoryLabel } from '../utils/index';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 6);
---

<BaseLayout
  title="kulachat — แนวคิดชีวิต การเดินทาง เทคโนโลยี"
  description="บันทึกส่วนตัวของ kulachat เขียนเรื่องแนวคิดชีวิต การเดินทาง และเทคโนโลยี"
>
  <Header />

  <main class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- Hero / Personal intro -->
    <section class="py-16 md:py-24">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-3">สวัสดีครับ</p>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6">
          ผมชื่อ <span class="text-blue-600">kulachat</span>
        </h1>
        <p class="text-xl text-gray-500 leading-relaxed mb-8">
          เขียนเรื่องที่คิดอยู่ในหัว — แนวคิดชีวิต การเดินทาง และเทคโนโลยี
          บางครั้งเป็นภาษาไทย บางครั้งเป็นภาษาอังกฤษ
        </p>
        <a href="/blog" class="btn-primary">
          อ่านบทความ →
        </a>
      </div>
    </section>

    <!-- Divider -->
    <hr class="border-gray-100" />

    <!-- Latest posts -->
    <section class="py-14">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-bold text-gray-900">บทความล่าสุด</h2>
        <a href="/blog" class="text-sm text-blue-600 hover:text-blue-700 font-medium transition-colors">
          ดูทั้งหมด →
        </a>
      </div>

      {latestPosts.length === 0 ? (
        <div class="text-center py-16 text-gray-400">
          <p class="text-lg">ยังไม่มีบทความ — เร็วๆ นี้</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {latestPosts.map(post => (
            <article class="group">
              {post.data.image && (
                <a href={`/blog/${post.slug}`} class="block mb-4 overflow-hidden rounded-xl aspect-video bg-gray-50">
                  <img
                    src={post.data.image.src}
                    alt={post.data.image.alt}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                </a>
              )}

              <div>
                <a
                  href={`/blog/category/${post.data.category}`}
                  class="category-badge"
                >
                  {getCategoryLabel(post.data.category)}
                </a>

                <h3 class="mt-1 text-lg font-bold text-gray-900 leading-snug group-hover:text-blue-600 transition-colors">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h3>

                <p class="mt-2 text-sm text-gray-500 line-clamp-2">
                  {post.data.description}
                </p>

                <div class="mt-3 flex items-center gap-3 text-xs text-gray-400">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {post.data.readingTime && (
                    <span>· {post.data.readingTime} นาที</span>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <!-- Topics section -->
    <section class="py-14 border-t border-gray-100">
      <h2 class="text-xl font-bold text-gray-900 mb-8">หมวดหมู่</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/blog/category/life" class="group p-6 rounded-xl border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-all">
          <div class="text-2xl mb-3">💭</div>
          <h3 class="font-bold text-gray-900 group-hover:text-blue-700">แนวคิดชีวิต</h3>
          <p class="text-sm text-gray-500 mt-1">ความคิด มุมมอง และบทเรียนจากชีวิต</p>
        </a>
        <a href="/blog/category/travel" class="group p-6 rounded-xl border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-all">
          <div class="text-2xl mb-3">✈️</div>
          <h3 class="font-bold text-gray-900 group-hover:text-blue-700">การเดินทาง</h3>
          <p class="text-sm text-gray-500 mt-1">ที่เที่ยว ประสบการณ์ และเรื่องราวระหว่างทาง</p>
        </a>
        <a href="/blog/category/tech" class="group p-6 rounded-xl border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-all">
          <div class="text-2xl mb-3">⚙️</div>
          <h3 class="font-bold text-gray-900 group-hover:text-blue-700">เทคโนโลยี</h3>
          <p class="text-sm text-gray-500 mt-1">เครื่องมือ AI และสิ่งที่อยากแชร์</p>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
