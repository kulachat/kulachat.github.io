---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCategoryLabel } from '../utils/index';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 8);
---

<BaseLayout
  title="kulachat — แนวคิดชีวิต การเดินทาง เทคโนโลยี"
  description="บันทึกส่วนตัวของ kulachat เขียนเรื่องแนวคิดชีวิต การเดินทาง และเทคโนโลยี"
>

  <main class="max-w-2xl mx-auto px-6 sm:px-8">

    <!-- Hero -->
    <section class="pt-20 pb-16 text-center">
      <img src="/images/Me.jpg" alt="kulachat" class="w-24 h-24 rounded-full object-cover mx-auto mb-6" />
      <h1 class="text-6xl md:text-7xl font-bold text-gray-900 leading-tight mb-6 font-google-sans">
        Decentralized Knowledge
      </h1>
      <p class="text-lg text-gray-700 leading-relaxed">
        <b>ผู้สนับสนุนการกระจายอำนาจความรู้  ❝เทคไทบ้าน❞ <br class="hidden sm:block" />
        เขียนเรื่องราว — แนวคิดชีวิต การเดินทาง และเทคโนโลยี</b>
      </p>
    </section>

    <!-- Latest posts -->
    <section class="py-14">

      {latestPosts.length === 0 ? (
        <div class="py-16 text-gray-400">
          <p>ยังไม่มีบทความ — เร็วๆ นี้</p>
        </div>
      ) : (
        <div class="divide-y divide-gray-100">
          {latestPosts.map(post => (
            <article class="py-7">
              <div class="flex items-baseline gap-4 mb-1">
                <time class="text-sm text-gray-400 shrink-0" datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span class="text-xs text-gray-300">—</span>
                <span class="text-xs text-gray-400 uppercase tracking-wide">
                  {getCategoryLabel(post.data.category)}
                </span>
              </div>
              <h2 class="text-[32px] font-bold text-gray-900 leading-snug hover:text-gray-600 transition-colors mb-2">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h2>
              <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">
                {post.data.description}
              </p>
            </article>
          ))}
        </div>
      )}

      <div class="pt-8">
        <a href="/blog" class="text-sm font-medium text-gray-900 underline underline-offset-2 hover:text-gray-600 transition-colors">
          ดูบทความทั้งหมด →
        </a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
