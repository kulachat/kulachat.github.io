---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getCategoryLabel } from '../../utils/index';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

// Group by year
const postsByYear: Record<number, typeof sortedPosts> = {};
for (const post of sortedPosts) {
  const year = new Date(post.data.publishDate).getFullYear();
  if (!postsByYear[year]) postsByYear[year] = [];
  postsByYear[year].push(post);
}
const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout
  title="บทความทั้งหมด — kulachat"
  description="บทความเรื่องแนวคิดชีวิต การเดินทาง และเทคโนโลยี โดย kulachat"
>

  <main class="max-w-2xl mx-auto px-6 sm:px-8">

    <!-- Page header -->
    <div class="pt-20 pb-10 border-b border-gray-200">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">บทความ</h1>

      <!-- Category filter -->
      <div class="flex items-center gap-3 flex-wrap">
        {[
          { href: '/blog', label: 'ทั้งหมด' },
          { href: '/blog/category/life', label: 'แนวคิดชีวิต' },
          { href: '/blog/category/travel', label: 'การเดินทาง' },
          { href: '/blog/category/tech', label: 'เทคโนโลยี' },
        ].map(cat => (
          <a
            href={cat.href}
            class="text-sm text-gray-500 hover:text-gray-900 transition-colors underline-offset-2 hover:underline"
          >
            {cat.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Archive by year -->
    {sortedPosts.length === 0 ? (
      <div class="py-20 text-gray-400">
        <p>ยังไม่มีบทความ — เร็วๆ นี้</p>
      </div>
    ) : (
      <div class="py-10 space-y-14">
        {years.map(year => (
          <section>
            <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-6">{year}</h2>
            <div class="divide-y divide-gray-100">
              {postsByYear[year].map(post => (
                <article class="py-5 flex gap-6 items-baseline">
                  <time
                    class="text-sm text-gray-400 shrink-0 w-24"
                    datetime={post.data.publishDate.toISOString()}
                  >
                    {post.data.publishDate.toLocaleDateString('th-TH', { month: 'long', day: 'numeric' })}
                  </time>
                  <div class="min-w-0">
                    <h3 class="text-base font-semibold text-gray-900 hover:text-gray-600 transition-colors leading-snug">
                      <a href={`/blog/${post.id}`}>{post.data.title}</a>
                    </h3>
                    <p class="text-sm text-gray-400 mt-0.5">{getCategoryLabel(post.data.category)}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    )}

  </main>

  <Footer />
</BaseLayout>
