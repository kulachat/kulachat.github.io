---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCategoryLabel } from '../../../utils/index';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(allPosts.map(p => p.data.category))];
  return categories.map(category => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.params;
const label = getCategoryLabel(category);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter(p => p.data.category === category)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---

<BaseLayout
  title={`${label} — kulachat`}
  description={`บทความหมวด ${label} โดย kulachat`}
>
  <Header />

  <main class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- Page header -->
    <div class="py-12 border-b border-gray-100">
      <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-1">
        <a href="/blog" class="hover:underline">บทความ</a>
      </p>
      <h1 class="text-3xl font-bold text-gray-900">{label}</h1>
      <p class="mt-1 text-sm text-gray-400">{posts.length} บทความ</p>
    </div>

    <!-- Category filter -->
    <div class="flex items-center gap-2 py-5 border-b border-gray-100 overflow-x-auto">
      {[
        { href: '/blog', label: 'ทั้งหมด' },
        { href: '/blog/category/life', label: 'แนวคิดชีวิต' },
        { href: '/blog/category/travel', label: 'การเดินทาง' },
        { href: '/blog/category/tech', label: 'เทคโนโลยี' },
      ].map(cat => (
        <a
          href={cat.href}
          class={`shrink-0 px-4 py-1.5 rounded-full text-sm font-medium border transition-all ${
            cat.href === `/blog/category/${category}`
              ? 'border-blue-600 text-blue-600 bg-blue-50'
              : 'border-gray-200 text-gray-600 hover:border-blue-300 hover:text-blue-600 hover:bg-blue-50'
          }`}
        >
          {cat.label}
        </a>
      ))}
    </div>

    <!-- Posts list -->
    <section class="py-10">
      {posts.length === 0 ? (
        <div class="text-center py-20 text-gray-400">
          <p class="text-lg">ยังไม่มีบทความในหมวดนี้</p>
        </div>
      ) : (
        <div class="divide-y divide-gray-100">
          {posts.map(post => (
            <article class="py-8 group flex gap-6">
              <div class="flex-1 min-w-0">
                <a
                  href={`/blog/category/${post.data.category}`}
                  class="category-badge"
                >
                  {getCategoryLabel(post.data.category)}
                </a>

                <h2 class="mt-1 text-xl font-bold text-gray-900 leading-snug group-hover:text-blue-600 transition-colors">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>

                <p class="mt-2 text-gray-500 line-clamp-2 text-sm leading-relaxed">
                  {post.data.description}
                </p>

                <div class="mt-3 flex items-center gap-3 text-xs text-gray-400">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString('th-TH', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  {post.data.readingTime && (
                    <span>· {post.data.readingTime} นาทีในการอ่าน</span>
                  )}
                </div>
              </div>

              {post.data.image && (
                <a
                  href={`/blog/${post.id}`}
                  class="shrink-0 w-24 h-24 sm:w-32 sm:h-24 rounded-lg overflow-hidden bg-gray-100"
                >
                  <img
                    src={post.data.image.src}
                    alt={post.data.image.alt}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                </a>
              )}
            </article>
          ))}
        </div>
      )}
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
