---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCategoryLabel } from '../utils/index';
import 'plyr/dist/plyr.css';

export interface Props {
  title: string;
  description: string;
  author: string;
  publishDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  image?: { src: string; alt: string };
  readingTime?: number;
}

const {
  title,
  description,
  author,
  publishDate,
  updatedDate,
  category,
  tags,
  image,
} = Astro.props;

const siteURL = "https://kulachat.github.io";
const canonicalURL = Astro.url.href;
const ogImage = image?.src ?? "/images/Me.jpg";

const formattedPublishDate = publishDate.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": ogImage.startsWith("http") ? ogImage : `${siteURL}${ogImage}`,
  "author": {
    "@type": "Person",
    "name": author,
    "url": siteURL,
  },
  "publisher": {
    "@type": "Person",
    "name": "kulachat",
    "url": siteURL,
  },
  "datePublished": publishDate.toISOString(),
  "dateModified": (updatedDate ?? publishDate).toISOString(),
  "url": canonicalURL,
  "inLanguage": "th",
  "keywords": tags.join(", "),
};
---

<BaseLayout
  title={`${title} — kulachat`}
  description={description}
  ogType="article"
  ogImage={ogImage}
  canonicalURL={canonicalURL}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="page-wrap">

    <!-- ─── HEADER (outside paper) ─── -->
    <div class="article-header">

      <!-- Meta row: category + date -->
      <div class="meta-row">
        <a href={`/blog/category/${category}`} class="meta-category">
          {getCategoryLabel(category)}
        </a>
        <span class="meta-dot">·</span>
        <time datetime={publishDate.toISOString()} class="meta-date">
          {formattedPublishDate}
        </time>
      </div>

      <!-- Big title -->
      <h1 class="article-title">{title}</h1>

    </div>

    <!-- ─── PAPER STACK (content) ─── -->
    <div class="paper-stack-wrap">
      <div class="paper-sheet paper-sheet-back"></div>
      <div class="paper-sheet paper-sheet-mid"></div>
      <div class="paper-stack">

        <!-- Featured image -->
        {image && (
          <div class="paper-image">
            <img src={image.src} alt={image.alt} />
          </div>
        )}

        <!-- Article body -->
        <article class="prose">
          <slot />
        </article>

        <!-- Author row inside paper -->
        <div class="paper-author">
          <a href="/" class="author-link">
            <img src="/images/Me.jpg" alt={author} class="author-avatar" />
            <div class="author-info">
              <span class="author-name">{author}</span>
              {updatedDate && <span class="updated-date"> · อัปเดต {formattedUpdatedDate}</span>}
            </div>
          </a>
          <button id="share-btn" class="share-btn" title="แชร์">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
            </svg>
          </button>
        </div>

        <!-- Back link -->
        <div class="paper-back">
          <a href="/blog" class="back-link">← กลับไปที่บทความทั้งหมด</a>
        </div>

      </div>
    </div>

    <Footer />
  </div>

  <!-- Plyr SVG sprite (inline to avoid async load race) -->
  <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" style="display:none" aria-hidden="true"><symbol id="plyr-airplay" viewBox="0 0 18 18"><path d="M16 1H2a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h3v-2H3V3h12v8h-2v2h3a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1"/><path d="M4 17h10l-5-6z"/></symbol><symbol id="plyr-captions-off" viewBox="0 0 18 18"><path fill-opacity=".5" fill-rule="evenodd" d="M1 1c-.6 0-1 .4-1 1v11c0 .6.4 1 1 1h4.6l2.7 2.7c.2.2.4.3.7.3s.5-.1.7-.3l2.7-2.7H17c.6 0 1-.4 1-1V2c0-.6-.4-1-1-1zm4.52 10.15c1.99 0 3.01-1.32 3.28-2.41l-1.29-.39c-.19.66-.78 1.45-1.99 1.45-1.14 0-2.2-.83-2.2-2.34 0-1.61 1.12-2.37 2.18-2.37 1.23 0 1.78.75 1.95 1.43l1.3-.41C8.47 4.96 7.46 3.76 5.5 3.76c-1.9 0-3.61 1.44-3.61 3.7s1.65 3.69 3.63 3.69m7.57 0c1.99 0 3.01-1.32 3.28-2.41l-1.29-.39c-.19.66-.78 1.45-1.99 1.45-1.14 0-2.2-.83-2.2-2.34 0-1.61 1.12-2.37 2.18-2.37 1.23 0 1.78.75 1.95 1.43l1.3-.41c-.28-1.15-1.29-2.35-3.25-2.35-1.9 0-3.61 1.44-3.61 3.7s1.65 3.69 3.63 3.69"/></symbol><symbol id="plyr-captions-on" viewBox="0 0 18 18"><path fill-rule="evenodd" d="M1 1c-.6 0-1 .4-1 1v11c0 .6.4 1 1 1h4.6l2.7 2.7c.2.2.4.3.7.3s.5-.1.7-.3l2.7-2.7H17c.6 0 1-.4 1-1V2c0-.6-.4-1-1-1zm4.52 10.15c1.99 0 3.01-1.32 3.28-2.41l-1.29-.39c-.19.66-.78 1.45-1.99 1.45-1.14 0-2.2-.83-2.2-2.34 0-1.61 1.12-2.37 2.18-2.37 1.23 0 1.78.75 1.95 1.43l1.3-.41C8.47 4.96 7.46 3.76 5.5 3.76c-1.9 0-3.61 1.44-3.61 3.7s1.65 3.69 3.63 3.69m7.57 0c1.99 0 3.01-1.32 3.28-2.41l-1.29-.39c-.19.66-.78 1.45-1.99 1.45-1.14 0-2.2-.83-2.2-2.34 0-1.61 1.12-2.37 2.18-2.37 1.23 0 1.78.75 1.95 1.43l1.3-.41c-.28-1.15-1.29-2.35-3.25-2.35-1.9 0-3.61 1.44-3.61 3.7s1.65 3.69 3.63 3.69"/></symbol><symbol id="plyr-download" viewBox="0 0 18 18"><path d="M9 13c.3 0 .5-.1.7-.3L15.4 7 14 5.6l-4 4V1H8v8.6l-4-4L2.6 7l5.7 5.7c.2.2.4.3.7.3m-7 2h14v2H2z"/></symbol><symbol id="plyr-enter-fullscreen" viewBox="0 0 18 18"><path d="M10 3h3.6l-4 4L11 8.4l4-4V8h2V1h-7zM7 9.6l-4 4V10H1v7h7v-2H4.4l4-4z"/></symbol><symbol id="plyr-exit-fullscreen" viewBox="0 0 18 18"><path d="M1 12h3.6l-4 4L2 17.4l4-4V17h2v-7H1zM16 .6l-4 4V1h-2v7h7V6h-3.6l4-4z"/></symbol><symbol id="plyr-fast-forward" viewBox="0 0 18 18"><path d="M7.875 7.171 0 1v16l7.875-6.171V17L18 9 7.875 1z"/></symbol><symbol id="plyr-muted" viewBox="0 0 18 18"><path d="m12.4 12.5 2.1-2.1 2.1 2.1 1.4-1.4L15.9 9 18 6.9l-1.4-1.4-2.1 2.1-2.1-2.1L11 6.9 13.1 9 11 11.1zM3.786 6.008H.714C.286 6.008 0 6.31 0 6.76v4.512c0 .452.286.752.714.752h3.072l4.071 3.858c.5.3 1.143 0 1.143-.602V2.752c0-.601-.643-.977-1.143-.601z"/></symbol><symbol id="plyr-pause" viewBox="0 0 18 18"><path d="M6 1H3c-.6 0-1 .4-1 1v14c0 .6.4 1 1 1h3c.6 0 1-.4 1-1V2c0-.6-.4-1-1-1m6 0c-.6 0-1 .4-1 1v14c0 .6.4 1 1 1h3c.6 0 1-.4 1-1V2c0-.6-.4-1-1-1z"/></symbol><symbol id="plyr-pip" viewBox="0 0 18 18"><path d="M13.293 3.293 7.022 9.564l1.414 1.414 6.271-6.271L17 7V1h-6z"/><path d="M13 15H3V5h5V3H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-6h-2z"/></symbol><symbol id="plyr-play" viewBox="0 0 18 18"><path d="M15.562 8.1 3.87.225c-.818-.562-1.87 0-1.87.9v15.75c0 .9 1.052 1.462 1.87.9L15.563 9.9c.584-.45.584-1.35 0-1.8"/></symbol><symbol id="plyr-restart" viewBox="0 0 18 18"><path d="m9.7 1.2.7 6.4 2.1-2.1c1.9 1.9 1.9 5.1 0 7-.9 1-2.2 1.5-3.5 1.5s-2.6-.5-3.5-1.5c-1.9-1.9-1.9-5.1 0-7 .6-.6 1.4-1.1 2.3-1.3l-.6-1.9C6 2.6 4.9 3.2 4 4.1 1.3 6.8 1.3 11.2 4 14c1.3 1.3 3.1 2 4.9 2 1.9 0 3.6-.7 4.9-2 2.7-2.7 2.7-7.1 0-9.9L16 1.9z"/></symbol><symbol id="plyr-rewind" viewBox="0 0 18 18"><path d="M10.125 1 0 9l10.125 8v-6.171L18 17V1l-7.875 6.171z"/></symbol><symbol id="plyr-settings" viewBox="0 0 18 18"><path d="M16.135 7.784a2 2 0 0 1-1.23-2.969c.322-.536.225-.998-.094-1.316l-.31-.31c-.318-.318-.78-.415-1.316-.094a2 2 0 0 1-2.969-1.23C10.065 1.258 9.669 1 9.219 1h-.438c-.45 0-.845.258-.997.865a2 2 0 0 1-2.969 1.23c-.536-.322-.999-.225-1.317.093l-.31.31c-.318.318-.415.781-.093 1.317a2 2 0 0 1-1.23 2.969C1.26 7.935 1 8.33 1 8.781v.438c0 .45.258.845.865.997a2 2 0 0 1 1.23 2.969c-.322.536-.225.998.094 1.316l.31.31c.319.319.782.415 1.316.094a2 2 0 0 1 2.969 1.23c.151.607.547.865.997.865h.438c.45 0 .845-.258.997-.865a2 2 0 0 1 2.969-1.23c.535.321.997.225 1.316-.094l.31-.31c.318-.318.415-.781.094-1.316a2 2 0 0 1 1.23-2.969c.607-.151.865-.547.865-.997v-.438c0-.451-.26-.846-.865-.997M9 12a3 3 0 1 1 0-6 3 3 0 0 1 0 6"/></symbol><symbol id="plyr-volume" viewBox="0 0 18 18"><path d="M15.6 3.3c-.4-.4-1-.4-1.4 0s-.4 1 0 1.4C15.4 5.9 16 7.4 16 9s-.6 3.1-1.8 4.3c-.4.4-.4 1 0 1.4.2.2.5.3.7.3.3 0 .5-.1.7-.3C17.1 13.2 18 11.2 18 9s-.9-4.2-2.4-5.7"/><path d="M11.282 5.282a.91.91 0 0 0 0 1.316c.735.735.995 1.458.995 2.402 0 .936-.425 1.917-.995 2.487a.91.91 0 0 0 0 1.316c.145.145.636.262 1.018.156a.7.7 0 0 0 .298-.156C13.773 11.733 14.13 10.16 14.13 9q.001-.255-.011-.51c-.053-.992-.319-2.005-1.522-3.208a.91.91 0 0 0-1.316 0m-7.495.726H.714C.286 6.008 0 6.31 0 6.76v4.512c0 .452.286.752.714.752h3.072l4.071 3.858c.5.3 1.143 0 1.143-.602V2.752c0-.601-.643-.977-1.143-.601z"/></symbol></svg>

</BaseLayout>

<script>
  // @ts-ignore — plyr uses export= style which conflicts with verbatimModuleSyntax; runtime is fine
  import Plyr from 'plyr';

  document.addEventListener('DOMContentLoaded', () => {
    const audioEls = document.querySelectorAll<HTMLAudioElement>('.podcast-player audio');
    audioEls.forEach(el => {
      new Plyr(el, {
        controls: ['play', 'progress', 'current-time', 'mute', 'volume'],
        invertTime: false,
        tooltips: { controls: false, seek: true },
        loadSprite: false,
      });
    });
  });

  const btn = document.getElementById('share-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      if (navigator.share) {
        await navigator.share({ title: document.title, url: window.location.href });
      } else {
        await navigator.clipboard.writeText(window.location.href);
        btn.title = 'คัดลอกลิงก์แล้ว!';
        setTimeout(() => { btn.title = 'แชร์'; }, 2000);
      }
    });
  }
</script>

<style>
  /* ── Page wrapper ── */
  .page-wrap {
    background: #ffffff;
    min-height: 100vh;
  }

  /* ── Article header (outside paper) ── */
  .article-header {
    max-width: 760px;
    margin: 0 auto;
    padding: 3.5rem 2rem 2.5rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    font-family: 'Sarabun', sans-serif;
    font-size: 0.9rem;
  }

  .meta-category {
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: underline;
    text-decoration-color: rgba(0,0,0,0.3);
    transition: text-decoration-color 0.15s;
  }
  .meta-category:hover { text-decoration-color: #1a1a1a; }

  .meta-dot {
    color: #999;
    font-weight: 400;
  }

  .meta-date {
    font-weight: 700;
    color: #1a1a1a;
  }

  .article-title {
    font-family: 'Prompt', sans-serif !important;
    font-size: clamp(2.5rem, 4vw + 1rem, 4.5rem);
    font-weight: 800;
    color: #111;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    text-align: center;
  }

  /* ── Paper stack ── */
  .paper-stack-wrap {
    position: relative;
    max-width: 928px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  /* Behind sheets — absolute, matching paper-stack size */
  .paper-sheet {
    position: absolute;
    background: #fff;
    border: 1px solid #e2e2e2;
    top: 0;
    left: 2rem;
    right: 2rem;
    bottom: 4rem;
  }

  .paper-sheet-back {
    transform: rotate(-2deg) translateX(-3px) translateY(6px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    z-index: 0;
  }

  .paper-sheet-mid {
    transform: rotate(2deg) translateX(2px) translateY(4px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    z-index: 1;
  }

  .paper-stack {
    position: relative;
    background: #fff;
    border: 1px solid #e8e8e8;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    z-index: 2;
  }

  /* ── Featured image ── */
  .paper-image {
    overflow: hidden;
    border-bottom: 1px solid #f0f0f0;
  }
  .paper-image img {
    width: 100%;
    height: auto;
    max-height: 420px;
    object-fit: cover;
    display: block;
  }

  /* ── Author row (inside paper) ── */
  .paper-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 2.5rem;
    border-top: 1px solid #f0f0f0;
  }

  .author-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex: 1;
  }

  .author-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .author-info {
    flex: 1;
    font-family: 'Sarabun', sans-serif;
  }

  .author-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
  }

  .updated-date {
    font-size: 0.8rem;
    color: #aaa;
  }

  .share-btn {
    padding: 0.375rem;
    color: #bbb;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 9999px;
    transition: color 0.15s, background 0.15s;
  }
  .share-btn:hover { color: #555; background: #f3f3f3; }

  /* ── Prose ── */
  .prose {
    padding: 4rem 2.5rem 2rem;
    max-width: 640px;
    margin: 0 auto;
    font-family: 'Sarabun', sans-serif;
    color: #1f1f1f;
    font-size: 1.0625rem;
    line-height: 2;
  }

  @media (max-width: 640px) {
    .article-header { padding: 2.5rem 1.25rem 1.5rem; }
    .paper-stack-wrap { padding: 0 1.25rem 3rem; }
    .paper-author { padding: 1.25rem 1.25rem; }
    .prose { padding: 2rem 1.25rem 1.5rem; }
    .paper-back { padding: 1rem 1.25rem 1.5rem; }
  }

  .prose h2 {
    font-family: 'Prompt', sans-serif !important;
    font-size: 1.5rem;
    font-weight: 700;
    color: #111;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose h3 {
    font-family: 'Prompt', sans-serif !important;
    font-size: 1.2rem;
    font-weight: 700;
    color: #111;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .prose p { margin-bottom: 1.75rem; }

  .prose a {
    color: #1f1f1f;
    text-decoration: underline;
    text-decoration-color: rgba(31,31,31,0.3);
    transition: text-decoration-color 0.15s;
  }
  .prose a:hover { text-decoration-color: #1f1f1f; }

  .prose blockquote {
    border-left: 3px solid #ddd;
    padding-left: 1.25rem;
    margin: 2rem 0;
    color: #666;
    font-style: italic;
    line-height: 1.8;
  }

  .prose code {
    background: #f5f5f5;
    color: #1f1f1f;
    padding: 0.1rem 0.35rem;
    border-radius: 0.2rem;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .prose pre {
    background: #1f1f1f;
    color: #e5e7eb;
    border-radius: 0.375rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .prose pre code { background: transparent; padding: 0; color: inherit; font-size: 0.875em; }

  .prose img { border-radius: 0.25rem; margin: 2rem 0; max-width: 100%; }

  .prose ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .prose ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .prose li { margin-bottom: 0.5rem; }

  .prose strong { font-weight: 700; color: #111; }

  .prose table { width: 100%; border-collapse: collapse; margin: 1.75rem 0; font-size: 0.95em; }
  .prose th { background: #f7f7f7; font-weight: 600; padding: 0.75rem; border: 1px solid #e5e5e5; text-align: left; }
  .prose td { padding: 0.75rem; border: 1px solid #e5e5e5; }

  /* ── Media card ── */
  :global(.media-card) {
    border: 1px solid #e8e8e8;
    border-radius: 1.25rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    overflow: hidden;
    margin: 2rem 0;
  }

  :global(.media-card img) {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    border-radius: 0;
  }

  /* ── Podcast player ── */
  :global(.podcast-player) {
    padding: 1.25rem 2rem;
    background: #fafafa;
  }

  :global(.podcast-meta) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Sarabun', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    margin-bottom: 0.75rem;
    padding: 0;
  }

  :global(.podcast-player audio) {
    width: 100%;
    display: block;
  }

  /* ── Plyr custom theme ── */
  :global(.plyr) {
    --plyr-color-main: #1a1a1a;
    --plyr-audio-controls-background: transparent;
    --plyr-audio-control-color: #555;
    --plyr-audio-control-color-hover: #1a1a1a;
    --plyr-range-fill-background: #1a1a1a;
    --plyr-range-thumb-background: #1a1a1a;
    --plyr-range-track-height: 3px;
    --plyr-range-thumb-height: 13px;
    --plyr-range-thumb-width: 13px;
    --plyr-font-family: 'Sarabun', sans-serif;
    --plyr-font-size-base: 0.85rem;
    font-family: 'Sarabun', sans-serif;
  }

  :global(.plyr--audio .plyr__controls) {
    background: transparent;
    border-radius: 0;
    padding: 4px 0;
  }

  :global(.plyr--audio) {
    border-radius: 0;
    box-shadow: none;
    border: none;
  }

  /* ── Back link ── */
  .paper-back {
    padding: 1.25rem 2.5rem 2rem;
    border-top: 1px solid #f0f0f0;
  }

  .back-link {
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
    font-family: 'Sarabun', sans-serif;
    transition: color 0.15s;
  }
  .back-link:hover { color: #111; }
</style>
