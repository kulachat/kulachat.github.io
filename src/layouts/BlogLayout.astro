---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCategoryLabel } from '../utils/index';

export interface Props {
  title: string;
  description: string;
  author: string;
  publishDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  image?: { src: string; alt: string };
  readingTime?: number;
}

const {
  title,
  description,
  author,
  publishDate,
  updatedDate,
  category,
  tags,
  image,
} = Astro.props;

const formattedPublishDate = publishDate.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const githubRepos = [
  {
    name: 'techthaiban-web',
    description: 'เว็บไซต์หลักของเทคไทบ้าน — ร่วม contribute เนื้อหาและ feature ใหม่',
    url: 'https://github.com/techthaiban',
    stars: null,
    lang: 'Astro',
  },
  {
    name: 'isaanjalearn',
    description: 'แพลตฟอร์มการเรียนรู้สำหรับคนอีสาน — open source ทุกคน',
    url: 'https://github.com/techthaiban',
    stars: null,
    lang: 'TypeScript',
  },
  {
    name: 'kulachat.github.io',
    description: 'บล็อกนี้นั่นแหละ — แก้ bug หรือ PR เพิ่ม feature ได้เลย',
    url: 'https://github.com/kulachat/kulachat.github.io',
    stars: null,
    lang: 'Astro',
  },
];
---

<BaseLayout title={`${title} — kulachat`} description={description}>
  <Header />

  <main class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Two-column layout: Left sidebar + Article (header lives inside content col) -->
    <div class="flex gap-12 pt-10">

      <!-- LEFT sidebar: GitHub repos (sticky, desktop only) -->
      <aside class="hidden w-56 shrink-0">
        <div class="sticky top-24 space-y-6 pt-1">
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">
            ร่วม Contribute
          </p>
          <p class="text-sm text-gray-500 leading-relaxed -mt-3">
            โปรเจกต์เหล่านี้เป็น open source — ถ้าอยากช่วย แก้ bug หรือเสนอ feature เปิด PR ได้เลยครับ
          </p>

          <div class="space-y-3">
            {githubRepos.map(repo => (
              <a
                href={repo.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block p-3 rounded-xl border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-all group"
              >
                <div class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 shrink-0 text-gray-400 group-hover:text-blue-500 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-gray-900 group-hover:text-blue-700 truncate transition-colors">
                      {repo.name}
                    </p>
                    <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">
                      {repo.description}
                    </p>
                    <span class="inline-block mt-1.5 text-xs text-gray-400">{repo.lang}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>

          <a
            href="https://github.com/techthaiban"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-medium text-blue-600 hover:text-blue-700 transition-colors"
          >
            ดูทั้งหมดใน GitHub →
          </a>
        </div>
      </aside>

      <!-- Content column: header + image + article -->
      <div class="flex-1 min-w-0 max-w-[680px] mx-auto">

        <!-- Article header -->
        <header class="pb-8 border-b border-gray-100">

          <!-- Category -->
          <a
            href={`/blog/category/${category}`}
            class="inline-block text-xs font-semibold uppercase tracking-widest text-blue-600 hover:text-blue-700 mb-4 transition-colors"
          >
            {getCategoryLabel(category)}
          </a>

          <!-- Title -->
          <h1 class="text-3xl sm:text-4xl md:text-[2.75rem] font-bold text-gray-900 mb-4" style="line-height: 1.5">
            {title}
          </h1>

          <!-- Description -->
          <p class="text-xl text-gray-500 leading-relaxed mb-6">
            {description}
          </p>

          <!-- Author row -->
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <img src="/images/Me.jpg" alt={author} class="w-10 h-10 rounded-full object-cover shrink-0" />
              <div>
                <p class="text-sm font-semibold text-gray-900">{author}</p>
                <div class="flex items-center gap-2 text-xs text-gray-400 mt-0.5">
                  <time datetime={publishDate.toISOString()}>{formattedPublishDate}</time>
                  {updatedDate && <span>· อัปเดต {formattedUpdatedDate}</span>}
                </div>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-1">
              <button
                id="share-btn"
                class="p-2 rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors"
                title="แชร์"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                </svg>
              </button>
              <button
                class="p-2 rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors"
                title="บันทึก"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                </svg>
              </button>
            </div>
          </div>
        </header>

        <!-- Featured image -->
        {image && (
          <div class="my-8 overflow-hidden rounded-2xl aspect-video bg-gray-50">
            <img src={image.src} alt={image.alt} class="w-full h-full object-cover" />
          </div>
        )}

        <!-- Article content -->
        <article class="py-8 prose prose-lg max-w-none">
          <slot />
        </article>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="pt-8 border-t border-gray-100">
            <div class="flex flex-wrap gap-2">
              {tags.map(tag => (
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Back to blog -->
        <div class="py-10 border-t border-gray-100 mt-8">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            กลับไปที่บทความทั้งหมด
          </a>
        </div>

      </div><!-- end content column -->

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const btn = document.getElementById('share-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      if (navigator.share) {
        await navigator.share({ title: document.title, url: window.location.href });
      } else {
        await navigator.clipboard.writeText(window.location.href);
        btn.title = 'คัดลอกลิงก์แล้ว!';
        setTimeout(() => { btn.title = 'แชร์'; }, 2000);
      }
    });
  }
</script>

<style>
  .prose {
    font-family: 'Sarabun', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #1f1f1f;
    font-size: 1.0625rem;
    line-height: 1.9;
  }

  .prose h2 {
    font-family: 'Prompt', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.5rem, 1.35rem + 0.5vw, 1.875rem);
    font-weight: 700;
    color: #1f1f1f;
    margin-top: 2.75rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .prose h3 {
    font-family: 'Prompt', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.2rem, 1.1rem + 0.3vw, 1.4rem);
    font-weight: 700;
    color: #1f1f1f;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .prose p {
    margin-bottom: 1.75rem;
  }

  .prose a {
    color: #3182CE;
    text-decoration: underline;
    text-decoration-color: rgba(49, 130, 206, 0.35);
    transition: color 0.15s;
  }

  .prose a:hover {
    color: #2b6cb0;
    text-decoration-color: #2b6cb0;
  }

  .prose blockquote {
    border-left: 3px solid #1f1f1f;
    padding-left: 1.5rem;
    margin: 2rem 0;
    color: #555;
    font-style: italic;
    font-size: 1.05em;
    line-height: 1.8;
  }

  .prose code {
    background: #f4f4f4;
    color: #1f1f1f;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .prose pre {
    background: #1f1f1f;
    color: #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .prose pre code {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: 0.875em;
  }

  .prose img {
    border-radius: 0.5rem;
    margin: 2rem 0;
  }

  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.6rem;
  }

  .prose strong {
    font-weight: 700;
    color: #1f1f1f;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-size: 0.95em;
  }

  .prose th {
    background: #f7fafc;
    font-weight: 600;
    color: #1f1f1f;
    padding: 0.75rem;
    border: 1px solid #e2e8f0;
    text-align: left;
  }

  .prose td {
    padding: 0.75rem;
    border: 1px solid #e2e8f0;
  }
</style>
