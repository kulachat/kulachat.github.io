---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCategoryLabel } from '../utils/index';

export interface Props {
  title: string;
  description: string;
  author: string;
  publishDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  image?: { src: string; alt: string };
  readingTime?: number;
}

const {
  title,
  description,
  author,
  publishDate,
  updatedDate,
  category,
  tags,
  image,
  readingTime,
} = Astro.props;

const formattedPublishDate = publishDate.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — kulachat`} description={description}>
  <Header />

  <main class="max-w-3xl mx-auto px-4 sm:px-6">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 pt-8 pb-2 text-xs font-semibold uppercase tracking-widest text-blue-600">
      <a href="/" class="hover:underline">หน้าแรก</a>
      <span class="text-gray-300">›</span>
      <a href="/blog" class="hover:underline">บทความ</a>
      <span class="text-gray-300">›</span>
      <a
        href={`/blog/category/${category}`}
        class="hover:underline"
      >
        {getCategoryLabel(category)}
      </a>
    </nav>

    <!-- Article header -->
    <header class="pt-4 pb-8 border-b border-gray-100">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6">
        {title}
      </h1>

      <div class="flex items-start gap-6">
        <!-- Date + reading time -->
        <div class="text-sm text-gray-500 shrink-0">
          <time datetime={publishDate.toISOString()} class="block">
            {formattedPublishDate}
          </time>
          {readingTime && (
            <span class="block mt-0.5">{readingTime} นาที</span>
          )}
        </div>

        <!-- Divider line -->
        <div class="w-px bg-gray-200 self-stretch shrink-0"></div>

        <!-- Description -->
        <p class="text-gray-600 text-base leading-relaxed">
          {description}
        </p>
      </div>

      <!-- Author -->
      <div class="flex items-center justify-between mt-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-sm shrink-0">
            {author.charAt(0).toUpperCase()}
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900">{author}</p>
            {updatedDate && (
              <p class="text-xs text-gray-400">อัปเดต {formattedUpdatedDate}</p>
            )}
          </div>
        </div>

      </div>
    </header>

    <!-- Featured image -->
    {image && (
      <div class="my-8 overflow-hidden rounded-2xl aspect-video bg-gray-50">
        <img
          src={image.src}
          alt={image.alt}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <!-- Article content -->
    <article class="py-8 prose prose-lg max-w-none">
      <slot />
    </article>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="pt-8 border-t border-gray-100">
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Back to blog -->
    <div class="py-10 border-t border-gray-100 mt-8">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        กลับไปที่บทความทั้งหมด
      </a>
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* Clean Google Blog-style prose */
  .prose {
    color: #374151;
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .prose h2 {
    font-size: 1.625rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .prose h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .prose p {
    margin-bottom: 1.5rem;
  }

  .prose a {
    color: #2563eb;
    text-decoration: underline;
    text-decoration-color: rgba(37, 99, 235, 0.3);
    transition: color 0.15s;
  }

  .prose a:hover {
    color: #1d4ed8;
    text-decoration-color: #1d4ed8;
  }

  .prose blockquote {
    border-left: 3px solid #e5e7eb;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: #6b7280;
    font-style: italic;
  }

  .prose code {
    background: #f3f4f6;
    color: #1f2937;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .prose pre {
    background: #1f2937;
    color: #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose pre code {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: 0.875em;
  }

  .prose img {
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }

  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose strong {
    font-weight: 600;
    color: #111827;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9em;
  }

  .prose th {
    background: #f9fafb;
    font-weight: 600;
    color: #111827;
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
    text-align: left;
  }

  .prose td {
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
  }

  /* Thai language */
  .prose :lang(th),
  .prose p,
  .prose li {
    font-family: 'Noto Sans Thai', 'Inter', sans-serif;
    line-height: 1.75;
  }
</style>
