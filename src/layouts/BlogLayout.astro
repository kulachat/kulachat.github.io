---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCategoryLabel } from '../utils/index';

export interface Props {
  title: string;
  description: string;
  author: string;
  publishDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  image?: { src: string; alt: string };
  readingTime?: number;
}

const {
  title,
  description,
  author,
  publishDate,
  updatedDate,
  category,
  tags,
  image,
} = Astro.props;

const siteURL = "https://kulachat.github.io";
const canonicalURL = Astro.url.href;
const ogImage = image?.src ?? "/images/Me.jpg";

const formattedPublishDate = publishDate.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": ogImage.startsWith("http") ? ogImage : `${siteURL}${ogImage}`,
  "author": {
    "@type": "Person",
    "name": author,
    "url": siteURL,
  },
  "publisher": {
    "@type": "Person",
    "name": "kulachat",
    "url": siteURL,
  },
  "datePublished": publishDate.toISOString(),
  "dateModified": (updatedDate ?? publishDate).toISOString(),
  "url": canonicalURL,
  "inLanguage": "th",
  "keywords": tags.join(", "),
};
---

<BaseLayout
  title={`${title} — kulachat`}
  description={description}
  ogType="article"
  ogImage={ogImage}
  canonicalURL={canonicalURL}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="page-wrap">

    <!-- ─── HEADER (outside paper) ─── -->
    <div class="article-header">

      <!-- Meta row: category + date -->
      <div class="meta-row">
        <a href={`/blog/category/${category}`} class="meta-category">
          {getCategoryLabel(category)}
        </a>
        <span class="meta-dot">·</span>
        <time datetime={publishDate.toISOString()} class="meta-date">
          {formattedPublishDate}
        </time>
      </div>

      <!-- Big title -->
      <h1 class="article-title">{title}</h1>

    </div>

    <!-- ─── PAPER STACK (content) ─── -->
    <div class="paper-stack-wrap">
      <div class="paper-sheet paper-sheet-back"></div>
      <div class="paper-sheet paper-sheet-mid"></div>
      <div class="paper-stack">

        <!-- Featured image -->
        {image && (
          <div class="paper-image">
            <img src={image.src} alt={image.alt} />
          </div>
        )}

        <!-- Article body -->
        <article class="prose">
          <slot />
        </article>

        <!-- Author row inside paper -->
        <div class="paper-author">
          <a href="/" class="author-link">
            <img src="/images/Me.jpg" alt={author} class="author-avatar" />
            <div class="author-info">
              <span class="author-name">{author}</span>
              {updatedDate && <span class="updated-date"> · อัปเดต {formattedUpdatedDate}</span>}
            </div>
          </a>
          <button id="share-btn" class="share-btn" title="แชร์">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
            </svg>
          </button>
        </div>

        <!-- Back link -->
        <div class="paper-back">
          <a href="/blog" class="back-link">← กลับไปที่บทความทั้งหมด</a>
        </div>

      </div>
    </div>

    <Footer />
  </div>

</BaseLayout>

<script>
  const btn = document.getElementById('share-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      if (navigator.share) {
        await navigator.share({ title: document.title, url: window.location.href });
      } else {
        await navigator.clipboard.writeText(window.location.href);
        btn.title = 'คัดลอกลิงก์แล้ว!';
        setTimeout(() => { btn.title = 'แชร์'; }, 2000);
      }
    });
  }
</script>

<style>
  /* ── Page wrapper ── */
  .page-wrap {
    background: #ffffff;
    min-height: 100vh;
  }

  /* ── Article header (outside paper) ── */
  .article-header {
    max-width: 760px;
    margin: 0 auto;
    padding: 3.5rem 2rem 2.5rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    font-family: 'Sarabun', sans-serif;
    font-size: 0.9rem;
  }

  .meta-category {
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: underline;
    text-decoration-color: rgba(0,0,0,0.3);
    transition: text-decoration-color 0.15s;
  }
  .meta-category:hover { text-decoration-color: #1a1a1a; }

  .meta-dot {
    color: #999;
    font-weight: 400;
  }

  .meta-date {
    font-weight: 700;
    color: #1a1a1a;
  }

  .article-title {
    font-family: 'Prompt', sans-serif !important;
    font-size: clamp(2.5rem, 4vw + 1rem, 4.5rem);
    font-weight: 800;
    color: #111;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    text-align: center;
  }

  /* ── Paper stack ── */
  .paper-stack-wrap {
    position: relative;
    max-width: 928px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  /* Behind sheets — absolute, matching paper-stack size */
  .paper-sheet {
    position: absolute;
    background: #fff;
    border: 1px solid #e2e2e2;
    top: 0;
    left: 2rem;
    right: 2rem;
    bottom: 4rem;
  }

  .paper-sheet-back {
    transform: rotate(-2deg) translateX(-3px) translateY(6px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    z-index: 0;
  }

  .paper-sheet-mid {
    transform: rotate(2deg) translateX(2px) translateY(4px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    z-index: 1;
  }

  .paper-stack {
    position: relative;
    background: #fff;
    border: 1px solid #e8e8e8;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    z-index: 2;
  }

  /* ── Featured image ── */
  .paper-image {
    overflow: hidden;
    border-bottom: 1px solid #f0f0f0;
  }
  .paper-image img {
    width: 100%;
    height: auto;
    max-height: 420px;
    object-fit: cover;
    display: block;
  }

  /* ── Author row (inside paper) ── */
  .paper-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 2.5rem;
    border-top: 1px solid #f0f0f0;
  }

  .author-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex: 1;
  }

  .author-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .author-info {
    flex: 1;
    font-family: 'Sarabun', sans-serif;
  }

  .author-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
  }

  .updated-date {
    font-size: 0.8rem;
    color: #aaa;
  }

  .share-btn {
    padding: 0.375rem;
    color: #bbb;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 9999px;
    transition: color 0.15s, background 0.15s;
  }
  .share-btn:hover { color: #555; background: #f3f3f3; }

  /* ── Prose ── */
  .prose {
    padding: 4rem 2.5rem 2rem;
    max-width: 640px;
    margin: 0 auto;
    font-family: 'Sarabun', sans-serif;
    color: #1f1f1f;
    font-size: 1.0625rem;
    line-height: 2;
  }

  @media (max-width: 640px) {
    .article-header { padding: 2.5rem 1.25rem 1.5rem; }
    .paper-stack-wrap { padding: 0 1.25rem 3rem; }
    .paper-author { padding: 1.25rem 1.25rem; }
    .prose { padding: 2rem 1.25rem 1.5rem; }
    .paper-back { padding: 1rem 1.25rem 1.5rem; }
  }

  .prose h2 {
    font-family: 'Prompt', sans-serif !important;
    font-size: 1.5rem;
    font-weight: 700;
    color: #111;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose h3 {
    font-family: 'Prompt', sans-serif !important;
    font-size: 1.2rem;
    font-weight: 700;
    color: #111;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .prose p { margin-bottom: 1.75rem; }

  .prose a {
    color: #1f1f1f;
    text-decoration: underline;
    text-decoration-color: rgba(31,31,31,0.3);
    transition: text-decoration-color 0.15s;
  }
  .prose a:hover { text-decoration-color: #1f1f1f; }

  .prose blockquote {
    border-left: 3px solid #ddd;
    padding-left: 1.25rem;
    margin: 2rem 0;
    color: #666;
    font-style: italic;
    line-height: 1.8;
  }

  .prose code {
    background: #f5f5f5;
    color: #1f1f1f;
    padding: 0.1rem 0.35rem;
    border-radius: 0.2rem;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .prose pre {
    background: #1f1f1f;
    color: #e5e7eb;
    border-radius: 0.375rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .prose pre code { background: transparent; padding: 0; color: inherit; font-size: 0.875em; }

  .prose img { border-radius: 0.25rem; margin: 2rem 0; max-width: 100%; }

  .prose ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .prose ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .prose li { margin-bottom: 0.5rem; }

  .prose strong { font-weight: 700; color: #111; }

  .prose table { width: 100%; border-collapse: collapse; margin: 1.75rem 0; font-size: 0.95em; }
  .prose th { background: #f7f7f7; font-weight: 600; padding: 0.75rem; border: 1px solid #e5e5e5; text-align: left; }
  .prose td { padding: 0.75rem; border: 1px solid #e5e5e5; }

  /* ── Media card ── */
  :global(.media-card) {
    border: 1px solid #e8e8e8;
    border-radius: 1.25rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    overflow: hidden;
    margin: 2rem 0;
  }

  :global(.media-card img) {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    border-radius: 0;
  }

  /* ── Podcast player ── */
  :global(.podcast-player) {
    padding: 1.25rem 2rem;
    background: #fafafa;
  }

  :global(.podcast-meta) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Sarabun', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    margin-bottom: 0.75rem;
    padding: 0;
  }

  :global(.podcast-player audio) {
    width: 100%;
    display: block;
  }

  /* ── Back link ── */
  .paper-back {
    padding: 1.25rem 2.5rem 2rem;
    border-top: 1px solid #f0f0f0;
  }

  .back-link {
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
    font-family: 'Sarabun', sans-serif;
    transition: color 0.15s;
  }
  .back-link:hover { color: #111; }
</style>
