---
---
<header class="sticky top-0 z-10 border-b border-sky-100 bg-white/95 backdrop-blur shadow-sm" role="banner">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-5 lg:px-8" aria-label="เมนูหลัก">

    <!-- Logo -->
    <a href="#" class="shrink-0" aria-label="a-achieve หน้าหลัก">
      <img src="https://a-chieve.org/assets/a-chieve.2d9a0e0d.svg" alt="a-achieve" class="h-8 w-auto" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 md:flex" role="list">
      <li><a href="#" class="rounded-full px-4 py-2 font-title font-medium text-slate-500 hover:bg-sky-50 hover:text-sky-600 transition-colors">ออกแบบเส้นทางชีวิต</a></li>
      <li><a href="#" class="rounded-full px-4 py-2 font-title font-medium text-slate-500 hover:bg-sky-50 hover:text-sky-600 transition-colors">สำรวจอารมณ์</a></li>
      <li><a href="#" class="rounded-full px-4 py-2 font-title font-medium text-slate-500 hover:bg-sky-50 hover:text-sky-600 transition-colors">คลังข้อมูลอาชีพ</a></li>
      <li><a href="#" class="rounded-full px-4 py-2 font-title font-medium text-slate-500 hover:bg-sky-50 hover:text-sky-600 transition-colors">บทความ</a></li>
      <li><a href="#" class="rounded-full px-4 py-2 font-title font-medium text-slate-500 hover:bg-sky-50 hover:text-sky-600 transition-colors">กิจกรรม</a></li>
    </ul>

    <!-- Right side: notification bell + user menu -->
    <div class="hidden items-center gap-2 md:flex">

      <!-- Notification bell -->
      <div class="relative" id="notifWrapper">
        <button class="relative grid h-10 w-10 place-items-center rounded-full border border-sky-100 bg-sky-50 text-sky-500 hover:bg-sky-100 transition-colors" type="button" id="notifButton" aria-label="การแจ้งเตือน" aria-expanded="false" aria-controls="notifDropdown">
          <span class="material-symbols-rounded text-[22px]">notifications</span>
          <span class="absolute right-1.5 top-1.5 hidden min-h-4 min-w-4 items-center justify-center rounded-full bg-gradient-to-r from-sky-500 to-blue-500 text-[10px] font-bold text-white" id="notifBadge"></span>
        </button>

        <!-- Notification dropdown -->
        <div class="absolute right-0 top-full z-20 mt-2 hidden w-80 overflow-hidden rounded-2xl border border-sky-100 bg-white shadow-card" id="notifDropdown" role="dialog" aria-label="การแจ้งเตือน">
          <div class="flex items-center justify-between border-b border-sky-100 bg-gradient-to-r from-sky-50 to-blue-50 px-4 py-3">
            <p class="font-semibold text-achieve-ink">การแจ้งเตือน</p>
            <span class="rounded-full bg-sky-100 px-2 py-0.5 text-xs font-semibold text-sky-700" id="notifHeaderBadge"></span>
          </div>
          <ul class="max-h-72 overflow-y-auto" id="notifList" role="list"></ul>
          <div class="border-t border-sky-100 bg-sky-50/40 px-4 py-3">
            <a href="#" class="flex items-center justify-center gap-1.5 text-sm font-semibold text-sky-500 hover:text-sky-600 transition-colors">
              ดูใบงานทั้งหมด
              <span class="material-symbols-rounded text-[16px]">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>

      <!-- User menu -->
      <div class="relative" id="userMenuWrapper">
        <button class="inline-flex min-h-10 shrink-0 items-center gap-2.5 rounded-full border border-sky-100 bg-sky-50 pl-1 pr-4 font-title font-medium text-slate-700 hover:bg-sky-100 transition-colors" type="button" id="userMenuButton" aria-label="เมนูผู้ใช้" aria-expanded="false" aria-controls="userDropdown">
          <span class="relative grid h-8 w-8 shrink-0 place-items-center rounded-full border-2 border-white bg-gradient-to-br from-sky-200 to-blue-200 text-lg shadow-soft">
            🧒
            <span class="absolute -right-0.5 -top-0.5 hidden h-3 w-3 rounded-full border-2 border-white bg-gradient-to-r from-sky-500 to-blue-500" id="avatarDot"></span>
          </span>
          <span class="text-sm leading-tight">
            <span class="block font-semibold text-achieve-ink">อาชีฟเวอร์</span>
            <span class="block text-xs font-normal text-slate-500">อาชีพที่ใช่</span>
          </span>
          <span class="material-symbols-rounded text-[18px] text-slate-400 transition-transform duration-200" id="userMenuChevron">expand_more</span>
        </button>

        <!-- Dropdown -->
        <div class="absolute right-0 top-full z-20 mt-2 hidden w-56 overflow-hidden rounded-2xl border border-sky-100 bg-white shadow-card" id="userDropdown" role="menu">
          <div class="border-b border-sky-100 bg-gradient-to-r from-sky-50 to-blue-50 px-4 py-3">
            <p class="font-semibold text-achieve-ink">อาชีฟเวอร์</p>
            <p class="text-xs text-slate-500">อาชีพที่ใช่</p>
          </div>
          <ul class="p-1.5">
            <li>
              <a href="#" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-slate-700 hover:bg-sky-50 transition-colors" role="menuitem">
                <span class="material-symbols-rounded text-[19px] text-slate-400">person</span>
                โปรไฟล์ของฉัน
              </a>
            </li>
            <li>
              <a href="#" class="flex items-center justify-between gap-3 rounded-xl px-3 py-2.5 text-slate-700 hover:bg-sky-50 transition-colors" role="menuitem" id="myAssignmentsLink">
                <span class="flex items-center gap-3">
                  <span class="material-symbols-rounded text-[19px] text-sky-500">assignment</span>
                  ใบงานของฉัน
                </span>
                <span class="hidden min-h-5 min-w-5 items-center justify-center rounded-full bg-gradient-to-r from-sky-500 to-blue-500 text-[11px] font-bold text-white" id="dropdownAssignmentBadge"></span>
              </a>
            </li>
            <li class="mx-1.5 my-1 h-px bg-sky-100"></li>
            <li>
              <a href="#" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-red-500 hover:bg-red-50 transition-colors" role="menuitem">
                <span class="material-symbols-rounded text-[19px]">logout</span>
                ออกจากระบบ
              </a>
            </li>
          </ul>
        </div>
      </div>

    </div><!-- end right side -->

    <!-- Mobile: bell + hamburger -->
    <div class="flex items-center gap-2 md:hidden">
      <div class="relative" id="notifWrapperMobile">
        <button class="relative grid h-10 w-10 place-items-center rounded-full border border-sky-100 bg-sky-50 text-sky-500 hover:bg-sky-100 transition-colors" type="button" id="notifButtonMobile" aria-label="การแจ้งเตือน">
          <span class="material-symbols-rounded text-[22px]">notifications</span>
          <span class="absolute right-1.5 top-1.5 hidden min-h-4 min-w-4 items-center justify-center rounded-full bg-gradient-to-r from-sky-500 to-blue-500 text-[10px] font-bold text-white" id="notifBadgeMobile"></span>
        </button>
      </div>

      <!-- Mobile hamburger -->
      <button class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-sky-100 bg-sky-50 text-sky-500 hover:bg-sky-100 transition-colors md:hidden" type="button" id="mobileMenuButton" aria-label="เปิดเมนู" aria-expanded="false" aria-controls="mobileMenu">
        <span class="material-symbols-rounded text-[22px]" id="mobileMenuIcon">menu</span>
      </button>
    </div><!-- end mobile right -->

  </nav>

  <!-- Mobile menu -->
  <div class="hidden border-t border-sky-100 bg-white px-5 pb-4 pt-2 md:hidden" id="mobileMenu">
    <ul class="grid gap-1" role="list">
      <li><a href="#" class="block rounded-xl px-4 py-3 font-title font-medium text-slate-600 hover:bg-sky-50 transition-colors">ออกแบบเส้นทางชีวิต</a></li>
      <li><a href="#" class="block rounded-xl px-4 py-3 font-title font-medium text-slate-600 hover:bg-sky-50 transition-colors">สำรวจอารมณ์</a></li>
      <li><a href="#" class="block rounded-xl px-4 py-3 font-title font-medium text-slate-600 hover:bg-sky-50 transition-colors">คลังข้อมูลอาชีพ</a></li>
      <li><a href="#" class="block rounded-xl px-4 py-3 font-title font-medium text-slate-600 hover:bg-sky-50 transition-colors">บทความ</a></li>
      <li><a href="#" class="block rounded-xl px-4 py-3 font-title font-medium text-slate-600 hover:bg-sky-50 transition-colors">กิจกรรม</a></li>
    </ul>
    <div class="mt-3 border-t border-sky-100 pt-3">
      <a href="#" class="flex items-center justify-between rounded-xl px-4 py-3 font-medium text-slate-700 hover:bg-sky-50 transition-colors">
        <span class="flex items-center gap-3">
          <span class="material-symbols-rounded text-[20px] text-sky-500">assignment</span>
          ใบงานของฉัน
        </span>
        <span class="hidden min-h-5 min-w-5 items-center justify-center rounded-full bg-gradient-to-r from-sky-500 to-blue-500 text-[11px] font-bold text-white" id="mobileAssignmentBadge"></span>
      </a>
    </div>
  </div>
</header>

<script>
  // ── Mobile menu ───────────────────────────────────────────────────────────────
  const mobileMenuButton = document.getElementById('mobileMenuButton');
  const mobileMenu = document.getElementById('mobileMenu');
  const mobileMenuIcon = document.getElementById('mobileMenuIcon');

  if (mobileMenuButton && mobileMenu && mobileMenuIcon) {
    mobileMenuButton.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden', isOpen);
      mobileMenuButton.setAttribute('aria-expanded', String(!isOpen));
      mobileMenuIcon.textContent = isOpen ? 'menu' : 'close';
    });
  }

  // ── Notification bell ─────────────────────────────────────────────────────────
  const notifButton = document.getElementById('notifButton');
  const notifDropdown = document.getElementById('notifDropdown');

  // ── User menu ─────────────────────────────────────────────────────────────────
  const userMenuButton = document.getElementById('userMenuButton');
  const userDropdown = document.getElementById('userDropdown');
  const userMenuChevron = document.getElementById('userMenuChevron');

  function closeNotifDropdown() {
    notifDropdown?.classList.add('hidden');
    notifButton?.setAttribute('aria-expanded', 'false');
  }

  function openNotifDropdown() {
    closeUserDropdown();
    notifDropdown?.classList.remove('hidden');
    notifButton?.setAttribute('aria-expanded', 'true');
    if (typeof (window as any).onNotifOpen === 'function') (window as any).onNotifOpen();
  }

  function closeUserDropdown() {
    userDropdown?.classList.add('hidden');
    userMenuButton?.setAttribute('aria-expanded', 'false');
    if (userMenuChevron) (userMenuChevron as HTMLElement).style.transform = '';
  }

  function openUserDropdown() {
    closeNotifDropdown();
    userDropdown?.classList.remove('hidden');
    userMenuButton?.setAttribute('aria-expanded', 'true');
    if (userMenuChevron) (userMenuChevron as HTMLElement).style.transform = 'rotate(180deg)';
  }

  notifButton?.addEventListener('click', e => {
    e.stopPropagation();
    notifDropdown?.classList.contains('hidden') ? openNotifDropdown() : closeNotifDropdown();
  });

  userMenuButton?.addEventListener('click', e => {
    e.stopPropagation();
    userDropdown?.classList.contains('hidden') ? openUserDropdown() : closeUserDropdown();
  });

  document.addEventListener('click', () => {
    closeNotifDropdown();
    closeUserDropdown();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      closeNotifDropdown();
      closeUserDropdown();
    }
  });
</script>
